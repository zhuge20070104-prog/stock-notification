# 复制为 .env.local 后填入真实值。.env.local 已在 .gitignore，不会入库。
#
#   cp .env.local.example .env.local

# --- AWS 凭证（必需）---
export AWS_ACCESS_KEY_ID="AKIA..."
export AWS_SECRET_ACCESS_KEY="..."
export AWS_REGION="ap-southeast-1"

# --- 前端 ↔ API 共享密钥（必需）---
# 第一次随便起一串长随机：openssl rand -hex 24
export TF_VAR_api_key="..."

# --- 推送通道（至少配一个，否则只能看 CloudWatch Logs）---
# 飞书自定义群机器人 webhook
export TF_VAR_feishu_webhook=""
# Server酱 SendKey (可选)
export TF_VAR_serverchan_sendkey=""
