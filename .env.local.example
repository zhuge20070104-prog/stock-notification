# 复制为 .env.local 后填入真实值。.env.local 已在 .gitignore，不会入库。
#
#   cp .env.local.example .env.local

# --- AWS 凭证（必需）---
export AWS_ACCESS_KEY_ID="AKIA..."
export AWS_SECRET_ACCESS_KEY="..."
export AWS_REGION="ap-southeast-1"

# --- 前端 ↔ API 共享密钥（必需）---
# 第一次随便起一串长随机：openssl rand -hex 24
export TF_VAR_api_key="..."

# --- 推送通道（至少配一个，否则只能看 CloudWatch Logs）---
# 飞书自定义群机器人 webhook
export TF_VAR_feishu_webhook=""
# Server酱 SendKey (可选)
export TF_VAR_serverchan_sendkey=""

# --- AI 评估 ---
# DashScope / 阿里云 MaaS API key
# - 个人公共 bailian: https://bailian.console.aliyun.com/ → API-KEY
# - 公司私有 MaaS workspace: 在 workspace 控制台拿 key 和 base url
# qwen-plus 月费约 ¥9，起充 ¥1。新用户每模型送 100 万 token 试用。
# 不配则 advisor 自动禁用，监控 Lambda 跑空。
export TF_VAR_dashscope_api_key=""

# 仅 MaaS 私有 workspace 用户需要填（公共 bailian 留空）
# 形如: https://ws-xxx.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
export TF_VAR_dashscope_base_url=""
